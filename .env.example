# --- ARIA CONFIGURATION ---

# AI Source: 'ollama' or 'mistral'
ARIA_AI_SOURCE=ollama

# Ollama Model (e.g., mistral-nemo:12b, llama3, phi3)
OLLAMA_MODEL_ID=mistral-nemo:12b
OLLAMA_HOST=http://localhost:11434

# Mistral Model (e.g., mistral-small-latest, mistral-large-latest)
MISTRAL_MODEL_ID=mistral-small-latest
MISTRAL_API_KEY=your_api_key_here

# Voice Configuration (TTS)
TTS_LANG=f
TTS_VOICE=ff_siwis
TTS_SPEED=1.0
