# Copy this file to `.env` and fill in your values.
# Never commit your real `.env` to GitHub.

# ============================================================
# Core I/O modes
# ============================================================
# audio: microphone push-to-talk + TTS playback
# text : terminal input/output
INPUT_MODE=audio
OUTPUT_MODE=audio

# ============================================================
# LLM (Brain)
# ============================================================
# Provider source: ollama | mistral | kobold
AI_SOURCE=ollama

# Model id:
# - Ollama example: mistral-nemo:12b
# - Mistral example: mistral-small-latest
AI_MODEL_ID=mistral-nemo:12b

# Ollama (optional)
OLLAMA_HOST=

# Mistral (required if AI_SOURCE=mistral)
MISTRAL_API_KEY=

# Kobold (required if AI_SOURCE=kobold)
KOBOLD_URL=http://localhost:5001/v1

# Sampling
TEMPERATURE=0.4

# Assistant response language enforced by system prompt
TARGET_LANGUAGE=English

# ============================================================
# Memory / Context
# ============================================================
# Max number of messages kept in the LLM prompt window
MEMORY_MAX_MESSAGES=20

# Context backend used by LangGraph checkpointer
# ram    : volatile (default)
# sqlite : persistent
CONTEXT_BACKEND=ram

# Used when CONTEXT_BACKEND=sqlite
CONTEXT_DB_PATH=data/context.db

# ============================================================
# Tavily web search (optional)
# ============================================================
# Required to actually perform web search
TAVILY_API_KEY=

# Tool behavior
TAVILY_MAX_RESULTS=4
TAVILY_RETURN_METADATA=true

# ============================================================
# Speech-to-Text (STT)
# ============================================================
# Used by core audio mode
STT_MODEL=small
STT_LANG=fr

# Legacy/demo keys (used only when running stt/micro_recorder.py directly)
ARIA_STT_MODEL=small
ARIA_STT_LANG=fr

# Optional: HuggingFace token (only needed for gated/private models)
HF_TOKEN=

# ============================================================
# Text-to-Speech (TTS)
# ============================================================
# Kokoro voice settings
TTS_LANG=f
TTS_SPEED=1.0

# Optional output device override (index or device name).
# Leave empty for auto behavior.
TTS_OUTPUT_DEVICE=
# Alternative name supported by code:
AUDIO_OUTPUT_DEVICE=

# ============================================================
# Scratchpad (optional)
# ============================================================
# Persistent scratchpad notes storage (JSON). Leave empty for RAM-only.
SCRATCHPAD_PATH=
