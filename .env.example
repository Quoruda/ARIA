# --- ARIA CONFIGURATION ---

# Optional: Hugging Face Token for faster/authenticated downloads
HF_TOKEN=your_hf_token_here

# AI Source: 'ollama' or 'mistral'
ARIA_AI_SOURCE=ollama

# Ollama Model (e.g., mistral-nemo:12b, llama3, phi3)
OLLAMA_MODEL_ID=mistral-nemo:12b
OLLAMA_HOST=http://localhost:11434

# Mistral Model (e.g., mistral-small-latest, mistral-large-latest)
MISTRAL_MODEL_ID=mistral-small-latest
MISTRAL_API_KEY=your_api_key_here

# Temperature for model responses (0.0-1.0, lower = more deterministic)
ARIA_TEMPERATURE=0.4

# Text-only mode (no TTS/STT, for silent testing)
ARIA_TEXT_MODE=0

# Voice Configuration (Text-to-Speech)
# TTS_LANG: language code (e.g., 'en' for English, 'fr' for French)
TTS_LANG=en
# TTS_VOICE: voice identifier (e.g., 'am_michael' for English male, 'af_sarah' for English female)
TTS_VOICE=am_michael
# TTS_SPEED: speech rate (0.5-2.0)
TTS_SPEED=1.0

# Speech Recognition (Speech-to-Text)
# ARIA_STT_MODEL: model size ('tiny', 'small', 'medium', 'large')
ARIA_STT_MODEL=small
# ARIA_STT_LANG: language code (e.g., 'en' for English, 'fr' for French)
ARIA_STT_LANG=en
