# ========================================
# ARIA - Configuration Environment
# ========================================

# ========================================
# HUGGING FACE
# ========================================
# Optional: Hugging Face Token for faster/authenticated downloads
HF_TOKEN=your_hf_token_here

# ========================================
# AI BRAIN / LLM CONFIGURATION
# ========================================
# AI Source: 'ollama' or 'mistral'
ARIA_AI_SOURCE=ollama

# Temperature for model responses (0.0-1.0, lower = more deterministic)
ARIA_TEMPERATURE=0.4

# Ollama Configuration (if ARIA_AI_SOURCE=ollama)
OLLAMA_MODEL_ID=mistral-nemo:12b
OLLAMA_HOST=http://localhost:11434

# Mistral Configuration (if ARIA_AI_SOURCE=mistral)
MISTRAL_MODEL_ID=mistral-small-latest
MISTRAL_API_KEY=your_api_key_here

# ========================================
# VOICE & AUDIO (TEXT-TO-SPEECH)
# ========================================
# Language code for Kokoro TTS (e.g., 'f' for French, 'en' for English)
TTS_LANG=f
# Voice identifier (e.g., 'af_heart' for French female, 'am_michael' for English male)
TTS_VOICE=af_heart
# Speech rate/speed (0.5-2.0, default 1.0)
TTS_SPEED=1.0

# ========================================
# SPEECH RECOGNITION (SPEECH-TO-TEXT)
# ========================================
# Model size: 'tiny', 'small', 'medium', 'large'
ARIA_STT_MODEL=small
# Language code (e.g., 'en' for English, 'fr' for French)
ARIA_STT_LANG=fr

# ========================================
# APPLICATION MODE
# ========================================
# Text-only mode (no TTS/STT, for silent testing): 0=disabled, 1=enabled
ARIA_TEXT_MODE=0
