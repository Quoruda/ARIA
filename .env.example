# ========================================
# ARIA - Configuration Environment
# ========================================

# ========================================
# HUGGING FACE
# ========================================
# Optional: Hugging Face Token for faster/authenticated downloads
HF_TOKEN=your_hf_token_here

# ========================================
# AI BRAIN / LLM CONFIGURATION
# ========================================
# AI Source: 'ollama' or 'mistral'
AI_SOURCE=ollama

# Model ID (used by both Ollama and Mistral)
# For Ollama: mistral-nemo:12b, mistral:7b, llama2, etc.
# For Mistral: mistral-small-latest, mistral-medium-latest, mistral-large-latest, etc.
AI_MODEL_ID=mistral-nemo:12b

# Temperature for model responses (0.0-1.0, lower = more deterministic)
TEMPERATURE=0.4

# Memory configuration
# Maximum number of messages to keep in conversation history (LLM+User)
MEMORY_MAX_MESSAGES=20

# Context Persistence / Checkpoint
# CONTEXT_BACKEND: 'ram' (volatile, default) or 'sqlite' (persistent)
CONTEXT_BACKEND=ram
# CONTEXT_DB_PATH: Path to the SQLite database if using 'sqlite' backbone
CONTEXT_DB_PATH=data/context.db

# Ollama Configuration (if AI_SOURCE=ollama)
OLLAMA_HOST=http://localhost:11434

# Mistral Configuration (if AI_SOURCE=mistral)
MISTRAL_API_KEY=your_api_key_here

# ========================================
# VOICE & AUDIO (TEXT-TO-SPEECH)
# ========================================
# Language code for Kokoro TTS (e.g., 'f' for French, 'en' for English)
TTS_LANG=f
# Speech rate/speed (0.5-2.0, default 1.0)
TTS_SPEED=1.0

# ========================================
# SPEECH RECOGNITION (SPEECH-TO-TEXT)
# ========================================
# Model size: 'tiny', 'small', 'medium', 'large'
STT_MODEL=small
# Language code (e.g., 'en' for English, 'fr' for French)
STT_LANG=fr

# Alternative STT configuration (if different from above)
# ARIA_STT_MODEL=small
# ARIA_STT_LANG=fr

# ========================================
# INPUT & OUTPUT MODES
# ========================================
# Input mode: 'text' for text input, 'audio' for speech input
INPUT_MODE=audio
# Output mode: 'text' for text output, 'audio' for speech output
OUTPUT_MODE=audio
